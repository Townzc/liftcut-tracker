# Copy this file to .env.local before running.

# Supabase project URL, e.g. https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key (public client key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI Provider: deepseek | local | openai_compatible
# Defaults to deepseek when omitted.
AI_PROVIDER=deepseek

# DeepSeek production provider (server-only)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Local research provider (OpenAI-compatible)
LOCAL_AI_BASE_URL=http://127.0.0.1:8000/v1
LOCAL_AI_API_KEY=EMPTY
LOCAL_AI_MODEL=liftcut-coach

# Generic OpenAI-compatible provider (server-only)
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# WeChat OAuth login (set to true only after Supabase custom provider "custom:wechat" is configured)
NEXT_PUBLIC_WECHAT_LOGIN_ENABLED=false
