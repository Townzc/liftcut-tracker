# Copy this file to .env.local before running.

# Supabase project URL, e.g. https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key (public client key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# DeepSeek OpenAI-compatible API key (server-only, never expose to browser)
DEEPSEEK_API_KEY=

# Optional: override DeepSeek base URL
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Optional: default model (recommended for v1: deepseek-chat)
DEEPSEEK_MODEL=deepseek-chat
